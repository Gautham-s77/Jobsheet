# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/job-tracker?retryWrites=true&w=majority

# CORS — frontend origin (no trailing slash)
CLIENT_URL=http://localhost:5173

# Firebase Admin — verify ID tokens from the web client
#
# The React app uses Firebase project jobhelper-19a89. The service account JSON MUST have
# "project_id": "jobhelper-19a89" or you will get: incorrect "aud" (audience) claim.
#
# This server loads credentials ONLY from a key file (credential.cert). It does NOT use
# Application Default Credentials (no gcloud application-default for auth).
#
# Firebase Console → Project settings → Service accounts → Generate new private key
#
# Option A — path to the downloaded *-firebase-adminsdk-*.json OR paste the whole JSON on one line:
FIREBASE_SERVICE_ACCOUNT=/absolute/path/to/jobhelper-19a89-firebase-adminsdk-xxxxx.json

# Option B — standard env name (path only); still loaded with cert(), not ADC:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/jobhelper-19a89-firebase-adminsdk-xxxxx.json

# Optional — if set, must match "project_id" inside the JSON; otherwise a warning is logged:
FIREBASE_PROJECT_ID=jobhelper-19a89
