# 🔐 Backend Environment Configuration

# Server Port
PORT=5000

# MongoDB Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
# Replace:
#   - username: Your MongoDB username
#   - password: Your MongoDB password
#   - cluster: Your cluster name (e.g., cluster0)
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/job-tracker?retryWrites=true&w=majority

# Node Environment
# Use 'development' for local development
# Use 'production' for live deployment
NODE_ENV=development

# (Optional) Frontend URL for CORS
# This allows the frontend to access the backend
CLIENT_URL=http://localhost:5173


mongodb+srv://thiruvallakanivu_db_user:<db_password>@cluster0.rz7bw9i.mongodb.net/?appName=Cluster0