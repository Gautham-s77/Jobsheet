/home/gautham-s-panicker/Downloads/# Backend API URL (include /api)
VITE_API_URL=http://localhost:5000/api

# Firebase Web App config (Firebase Console → Project settings → Your apps → Web)
# Create a Web app, then enable Authentication → Sign-in method: Google, Email/Password
# Add authorized domains: localhost, and your production domain
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional; enables Firebase Analytics when set
VITE_FIREBASE_MEASUREMENT_ID=
